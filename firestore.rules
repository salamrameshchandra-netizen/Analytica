rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global safety net - default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global and reuse helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Users and their private squads
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) 
        && request.resource.data.uid == userId
        && request.resource.data.uid is string;
      allow delete: if false;

      match /players/{playerId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(playerId);
      }
    }

    // Shared squads mapped by short-code or unique squad ID
    match /shared_squads/{squadId} {
      allow get: if isValidId(squadId);
      allow list: if false; // Anti-QueryScraping Gate
      allow create: if isValidId(squadId)
        && request.resource.data.code is string
        && request.resource.data.code.size() <= 16;
      allow update, delete: if false; // Shared squads are immutable once saved

      match /players/{playerId} {
        allow read, list: if isValidId(squadId);
        allow create: if isValidId(squadId) && isValidId(playerId);
        allow update, delete: if false; // Immutable players inside shared squads
      }
    }
  }
}
